---
import { SITE, FOOTER_COLUMNS } from '@/data/site';

const year = new Date().getFullYear();
---

<footer class="relative border-t border-[var(--rpix-border)] mt-auto overflow-hidden">
  <!-- Ambient gold glow -->
  <div
    class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-20"
    style="background: radial-gradient(ellipse, rgba(201,168,76,0.25), transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="container-rpix section-rpix !pb-12 relative">
    <!-- Top CTA -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-20" data-reveal>
      <div class="max-w-xl">
        <p class="text-label text-[var(--rpix-gold)] mb-4">Begin</p>
        <h2 class="text-display mb-6">
          Let's make<br />something lasting.
        </h2>
        <p class="text-[var(--rpix-muted-fg)] text-body-lg max-w-md">
          Selective collaborations in photography, film, and color. Tell us about your next image.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact" class="btn btn-primary btn-lg" data-magnetic data-cursor="Contact">
          Start a Project
        </a>
        <a href="/portfolio" class="btn btn-secondary btn-lg" data-magnetic>
          View Work
        </a>
      </div>
    </div>

    <hr class="divider mb-16" />

    <!-- Columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-10 mb-20">
      <div class="col-span-2 md:col-span-4 lg:col-span-1 mb-4 lg:mb-0">
        <a href="/" class="font-[family-name:var(--font-display)] text-lg tracking-[0.35em]">
          RPIX
        </a>
        <p class="mt-4 text-sm text-[var(--rpix-muted-fg)] max-w-[220px]">
          {SITE.tagline}
        </p>
        <p class="mt-6 text-sm text-[var(--rpix-muted-fg)]">
          {SITE.contact.location}
        </p>
        <a
          href={`mailto:${SITE.contact.email}`}
          class="mt-1 block text-sm text-[var(--rpix-fg)] hover:text-[var(--rpix-gold)] transition-colors"
        >
          {SITE.contact.email}
        </a>
      </div>

      {
        FOOTER_COLUMNS.map((col) => (
          <div>
            <p class="text-label text-[var(--rpix-muted-fg)] mb-5">{col.title}</p>
            <ul class="flex flex-col gap-3">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-sm text-[var(--rpix-secondary-fg)] hover:text-[var(--rpix-gold)] transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <!-- Newsletter -->
      <div class="col-span-2 md:col-span-1">
        <p class="text-label text-[var(--rpix-muted-fg)] mb-5">Newsletter</p>
        <p class="text-sm text-[var(--rpix-muted-fg)] mb-4">
          Occasional notes on craft. No noise.
        </p>
        <form class="flex flex-col gap-2" data-newsletter onsubmit="return false;">
          <input
            type="email"
            required
            placeholder="Email address"
            class="input-rpix !py-2.5 !text-sm"
            aria-label="Email for newsletter"
          />
          <button type="submit" class="btn btn-secondary btn-sm w-full">
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 pt-8 border-t border-[var(--rpix-border)]">
      <p class="text-xs text-[var(--rpix-muted-fg)]">
        © {year} RPIX Studio. All rights reserved.
      </p>

      <div class="flex items-center gap-5">
        {
          Object.entries(SITE.social).map(([name, url]) =>
            url ? (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs uppercase tracking-widest text-[var(--rpix-muted-fg)] hover:text-[var(--rpix-gold)] transition-colors"
                data-cursor={name}
              >
                {name}
              </a>
            ) : null,
          )
        }
      </div>

      <div class="flex items-center gap-4 text-xs text-[var(--rpix-muted-fg)]">
        <a href="/faq" class="hover:text-[var(--rpix-fg)] transition-colors">FAQ</a>
        <a href="/members" class="hover:text-[var(--rpix-fg)] transition-colors">Members</a>
        <a href="/admin" class="hover:text-[var(--rpix-gold)] transition-colors" data-no-transition>
          Admin
        </a>
      </div>
    </div>
  </div>
</footer>

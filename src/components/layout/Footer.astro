---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand Column -->
      <div class="col-brand">
        <a href="/" class="brand-logo" dir="ltr">
          <img src="/logo.png" alt="RPIX" width="52" height="52" />
          <div>
            <span class="brand-name font-display">RPIX</span>
            <span class="brand-sub">Rezapix</span>
          </div>
        </a>
        <p class="brand-bio">
          عکاسی هنری، ویدیوگرافی و خلق تصویر بصری — از ایران برای جهان.
        </p>
        <a href="mailto:RpiX1@proton.me" class="brand-email text-red" dir="ltr">
          RpiX1@proton.me
        </a>
      </div>

      <!-- Navigation Column -->
      <div class="col">
        <h4 class="col-title">ناوبری</h4>
        <ul class="col-links">
          <li><a href="/">خانه</a></li>
          <li><a href="/portfolio">پورتفولیو</a></li>
          <li><a href="/blog">بلاگ</a></li>
          <li><a href="/about">درباره من</a></li>
          <li><a href="/contact">تماس</a></li>
        </ul>
      </div>

      <!-- Categories Column -->
      <div class="col">
        <h4 class="col-title">دسته‌بندی</h4>
        <ul class="col-links">
          <li><a href="/portfolio/portrait">پرتره</a></li>
          <li><a href="/portfolio/landscape">منظره</a></li>
          <li><a href="/portfolio/bw">سیاه و سفید</a></li>
          <li><a href="/portfolio/video">ویدیو</a></li>
        </ul>
      </div>

      <!-- Social Column -->
      <div class="col">
        <h4 class="col-title">شبکه‌های اجتماعی</h4>
        <div class="social-grid">
          {socials.map(s => (
            <a href={s.href}
               class="social-btn glass"
               target={s.href !== '#' ? '_blank' : undefined}
               rel="noopener noreferrer"
               aria-label={s.name}
               title={s.name}>
              <Fragment set:html={icons[s.icon]} />
            </a>
          ))}
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="copy">© {year} RPIX — Rezapix. تمام حقوق محفوظ است.</p>
      <p class="made">ساخته شده با ❤ در ایران</p>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--glass-border);
  background: linear-gradient(0deg, var(--bg-void) 0%, transparent 100%);
  padding-top: var(--s16);
  padding-bottom: var(--s8);
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--s12);
  margin-bottom: var(--s12);
}
.brand-logo {
  display: flex; align-items: center; gap: var(--s3);
  margin-bottom: var(--s5);
}
.brand-logo img {
  object-fit: contain;
  filter: drop-shadow(0 0 8px rgba(204,0,0,0.3));
}
.brand-name {
  display:block; font-size:var(--2xl);
  font-weight:800; font-style:italic; color:var(--text-1);
}
.brand-sub {
  display:block; font-size:var(--xs); color:var(--text-3); letter-spacing:.1em;
}
.brand-bio {
  font-size:var(--sm); color:var(--text-2); line-height:1.8; margin-bottom:var(--s4);
}
.brand-email {
  font-size:var(--sm); font-family:var(--font-en); transition:opacity var(--t-fast);
}
.brand-email:hover { opacity:.7; }

.col-title {
  font-size:var(--sm); font-weight:600; color:var(--text-1);
  letter-spacing:.05em; margin-bottom:var(--s4);
}
.col-links { display:flex; flex-direction:column; gap:var(--s3); }
.col-links a { font-size:var(--sm); color:var(--text-2); transition:color var(--t-fast); }
.col-links a:hover { color:var(--red); }

.social-grid { display:flex; flex-wrap:wrap; gap:var(--s2); }
.social-btn {
  width:38px; height:38px;
  display:flex; align-items:center; justify-content:center;
  border-radius:var(--r-md); color:var(--text-2);
  transition:all var(--t-fast); flex-shrink:0;
}
.social-btn svg { width:17px; height:17px; }
.social-btn:hover { color:var(--red); border-color:var(--glass-red-b); background:var(--glass-red); }

.footer-bottom {
  padding-top:var(--s6);
  border-top:1px solid var(--glass-border);
  display:flex; justify-content:space-between; align-items:center;
  flex-wrap:wrap; gap:var(--s4);
}
.copy,.made { font-size:var(--xs); color:var(--text-3); }

@media(max-width:1024px){
  .footer-grid { grid-template-columns:1fr 1fr; gap:var(--s8); }
  .col-brand { grid-column:1/-1; }
}
@media(max-width:640px){
  .footer-grid { grid-template-columns:1fr; }
  .col-brand { grid-column:auto; }
  .footer-bottom { flex-direction:column; text-align:center; }
}
</style>

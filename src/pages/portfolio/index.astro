---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PortfolioCard from '@/components/ui/PortfolioCard.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { PORTFOLIO } from '@/data/content';

const types = ['all', 'photography', 'videography', 'color-grading'] as const;
const filter = Astro.url.searchParams.get('type') ?? 'all';
const items =
  filter === 'all' ? PORTFOLIO : PORTFOLIO.filter((p) => p.type === filter);
---

<BaseLayout
  title="Portfolio"
  description="Selected photography, videography, and color grading from RPIX studio."
>
  <section class="pt-36 pb-12">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Archive"
        title="Portfolio"
        description="An evolving collection of still and moving images — commercial, personal, and graded work."
        class="mb-12"
      />

      <div class="flex flex-wrap gap-2 mb-14" role="tablist" aria-label="Filter portfolio" data-reveal>
        {
          types.map((t) => (
            <a
              href={t === 'all' ? '/portfolio' : `/portfolio?type=${t}`}
              role="tab"
              aria-selected={filter === t}
              class:list={[
                'btn btn-sm',
                filter === t ? 'btn-primary' : 'btn-secondary',
              ]}
            >
              {t === 'all' ? 'All' : t.replace('-', ' ')}
            </a>
          ))
        }
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        {
          items.map((item, i) => (
            <PortfolioCard item={item} index={i} large={i % 5 === 0} />
          ))
        }
      </div>

      {
        items.length === 0 && (
          <p class="text-[var(--rpix-muted-fg)] py-20 text-center">No work in this category yet.</p>
        )
      }
    </div>
  </section>
</BaseLayout>

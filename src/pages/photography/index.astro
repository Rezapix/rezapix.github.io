---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PortfolioCard from '@/components/ui/PortfolioCard.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { PORTFOLIO } from '@/data/content';

const items = PORTFOLIO.filter((p) => p.type === 'photography');
---

<BaseLayout
  title="Photography"
  description="Cinematic still photography — campaign, editorial, landscape, and still life from RPIX."
>
  <section class="pt-36 pb-24">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Discipline 01"
        title="Photography"
        description="Still images built with the discipline of cinema — light as material, shadow as language."
        class="mb-16"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        {items.map((item, i) => <PortfolioCard item={item} index={i} />)}
      </div>
    </div>
  </section>
</BaseLayout>

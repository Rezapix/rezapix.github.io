---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MediaPlaceholder from '@/components/ui/MediaPlaceholder.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { PROJECTS } from '@/data/content';
---

<BaseLayout
  title="Projects"
  description="Long-form case studies from RPIX collaborations."
>
  <section class="pt-36 pb-24">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Case Studies"
        title="Projects"
        description="Extended narratives behind select collaborations — challenge, process, and result."
        class="mb-16"
      />

      <div class="flex flex-col gap-20">
        {
          PROJECTS.map((project, i) => (
            <a
              href={`/projects/${project.slug}`}
              class="group grid lg:grid-cols-2 gap-8 lg:gap-14 items-center"
              data-reveal
              data-cursor="Open"
            >
              <div class:list={[i % 2 === 1 && 'lg:order-2']}>
                <MediaPlaceholder label={project.title} aspect="wide" class="rounded-xl" gold={i === 0} />
              </div>
              <div class:list={[i % 2 === 1 && 'lg:order-1']}>
                <p class="text-label text-[var(--rpix-gold)] mb-3">
                  {project.client} · {project.year}
                </p>
                <h2 class="text-h1 mb-4 group-hover:text-[var(--rpix-gold)] transition-colors">
                  {project.title}
                </h2>
                <p class="text-[var(--rpix-muted-fg)] mb-6 max-w-md">{project.excerpt}</p>
                <div class="flex flex-wrap gap-2 mb-6">
                  {project.services.map((s) => (
                    <span class="text-label px-3 py-1 rounded-full border border-[var(--rpix-border)] text-[var(--rpix-muted-fg)]">
                      {s}
                    </span>
                  ))}
                </div>
                <span class="inline-flex items-center gap-2 text-sm group-hover:gap-3 transition-all">
                  View case study
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

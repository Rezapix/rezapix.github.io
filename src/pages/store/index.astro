---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MediaPlaceholder from '@/components/ui/MediaPlaceholder.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { PRODUCTS } from '@/data/content';
import { formatPrice } from '@/lib/utils/format';
---

<BaseLayout
  title="Store"
  description="LUTs, presets, and fine art prints from the RPIX studio."
>
  <section class="pt-36 pb-24">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Store"
        title="Tools & editions."
        description="Digital tools used in real client work, and limited fine art prints."
        class="mb-16"
      />

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" data-reveal-stagger>
        {
          PRODUCTS.map((product) => (
            <a
              href={`/store/${product.slug}`}
              class="group surface-card overflow-hidden flex flex-col"
              data-reveal-child
              data-cursor="View"
            >
              <MediaPlaceholder
                label={product.title}
                aspect="square"
                class="rounded-none"
                gold={product.featured}
              />
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h3 class="text-h3 group-hover:text-[var(--rpix-gold)] transition-colors">
                    {product.title}
                  </h3>
                  <span class="text-sm tabular-nums text-[var(--rpix-gold)] shrink-0">
                    {formatPrice(product.price, product.currency)}
                  </span>
                </div>
                {product.compareAtPrice && (
                  <p class="text-xs text-[var(--rpix-muted-fg)] line-through mb-2">
                    {formatPrice(product.compareAtPrice, product.currency)}
                  </p>
                )}
                <p class="text-sm text-[var(--rpix-muted-fg)] line-clamp-2 mb-4 flex-1">
                  {product.excerpt}
                </p>
                <span class="text-label text-[var(--rpix-muted-fg)]">{product.type}</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

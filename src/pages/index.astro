---
import Base from '../layouts/Base.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

const categories = [
  {
    id: 'portrait', fa: 'پرتره', en: 'Portrait',
    desc: 'روایت بصری از روح انسان در لحظه',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    isMain: true,
  },
  {
    id: 'landscape', fa: 'منظره', en: 'Landscape',
    desc: 'طبیعت در قاب‌های سینماتیک',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20h18L13 7 9 14l-3-3z"/><circle cx="18" cy="8" r="2"/></svg>`,
  },
  {
    id: 'bw', fa: 'سیاه و سفید', en: 'Black & White',
    desc: 'هنر روایت بدون رنگ',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 3v18" opacity=".4"/><path d="M12 3a9 9 0 0 1 0 18z" fill="currentColor" opacity=".15"/></svg>`,
  },
  {
    id: 'video', fa: 'ویدیو', en: 'Video',
    desc: 'تصویر در جریان زمان',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M15 10l4.553-2.069A1 1 0 0 1 21 8.88v6.24a1 1 0 0 1-1.447.89L15 14"/><rect x="3" y="8" width="12" height="8" rx="2"/></svg>`,
  },
];

const skills = ['عکاسی هنری','ویدیوگرافی','تدوین','گریدینگ رنگ','طراحی لوگو','موشن گرافیک'];

const typewriterTexts = [
  'عکاس هنری',
  'ویدیوگرافر',
  'خالق تصویر بصری',
  'Fine Art Photographer',
  'Visual Storyteller',
];
---

<Base
  title="RPIX — Rezapix | عکاسی هنری و ویدیوگرافی"
  description="پرتفولیو رضاپیکس — عکاس هنری، پرتره، منظره، سیاه و سفید و ویدیو از ایران"
>
  <Navbar />
  <main>

    <!-- ████████ HERO ████████ -->
    <section class="hero" id="home">

      <!-- Aurora blobs -->
      <div class="aurora" aria-hidden="true">
        <div class="blob b1"></div>
        <div class="blob b2"></div>
        <div class="blob b3"></div>
      </div>

      <!-- Grid overlay -->
      <div class="grid-lines" aria-hidden="true"></div>

      <!-- Noise overlay -->
      <div class="noise" aria-hidden="true"></div>

      <div class="container hero-inner">

        <!-- Logo mark + orbits -->
        <div class="logo-wrap" aria-hidden="true">
          <div class="orbit o1"></div>
          <div class="orbit o2"></div>
          <img src="/logo.png" alt="" class="hero-logo" width="110" height="110" />
        </div>

        <!-- Eyebrow -->
        <div class="eyebrow">
          <span class="line" aria-hidden="true"></span>
          <span class="tag">عکاسی هنری</span>
          <span class="line" aria-hidden="true"></span>
        </div>

        <!-- Title -->
        <h1 class="hero-title font-display">
          REZ<em class="text-red">A</em>PIX
        </h1>

        <!-- Typewriter subtitle -->
        <p class="hero-sub" dir="auto">
          <span id="tw" aria-live="polite"></span><span class="cursor" aria-hidden="true">|</span>
        </p>

        <!-- CTA buttons -->
        <div class="hero-ctas">
          <a href="/portfolio" class="btn btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            پورتفولیو
          </a>
          <a href="#contact" class="btn btn-ghost">تماس با من</a>
        </div>

        <!-- Stats -->
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-n font-display">۴</span>
            <span class="stat-l">دسته‌بندی</span>
          </div>
          <div class="vline" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-n font-display">∞</span>
            <span class="stat-l">خلاقیت</span>
          </div>
          <div class="vline" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-n font-display">۱</span>
            <span class="stat-l">دیدگاه</span>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <a href="#portfolio" class="scroll-ind" aria-label="اسکرول به پایین">
        <div class="scroll-pill"></div>
      </a>
    </section>

    <!-- ████████ PORTFOLIO GRID ████████ -->
    <section class="section" id="portfolio">
      <div class="container">

        <div class="section-header reveal">
          <span class="tag">آثار</span>
          <h2 class="section-title font-display">پورتفولیو</h2>
          <div class="divider divider-center"></div>
          <p class="section-desc">هر قاب روایتی‌ست از دیدگاه من به جهان اطراف</p>
        </div>

        <div class="port-grid">
          {categories.map((c, i) => (
            <a
              href={`/portfolio/${c.id}`}
              class={`port-card reveal delay-${i+1} ${c.isMain ? 'port-card-main' : ''}`}
            >
              <div class="card-icon" set:html={c.icon} />
              <div class="card-body">
                <h3 class="card-fa">{c.fa}</h3>
                <span class="card-en font-en">{c.en}</span>
                <p class="card-desc">{c.desc}</p>
              </div>
              <div class="card-foot">
                <span class="card-count text-3">به‌زودی</span>
                <span class="card-arr">→</span>
              </div>
            </a>
          ))}
        </div>

        <div class="port-cta reveal">
          <a href="/portfolio" class="btn btn-ghost">
            مشاهده همه آثار
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ████████ ABOUT ████████ -->
    <section class="section about-sec" id="about">
      <div class="container">
        <div class="about-grid">

          <!-- Visual -->
          <div class="about-vis reveal">
            <div class="about-ring glass-red">
              <img src="/logo.png" alt="RPIX" class="about-logo" width="160" height="160" />
              <div class="about-glow" aria-hidden="true"></div>
            </div>
            <div class="available glass">
              <span class="dot" aria-hidden="true"></span>
              <span>در دسترس برای پروژه</span>
            </div>
          </div>

          <!-- Text -->
          <div class="about-text reveal delay-2">
            <span class="tag">درباره من</span>
            <h2 class="about-title font-display">
              من <em class="text-red">رضاپیکس</em> هستم
            </h2>
            <div class="divider"></div>
            <p class="about-p">
              عکاس هنری و ویدیوگراف مستقل — با دیدگاهی سینماتیک و زیبایی‌شناسی ویژه،
              لحظات را به تصاویر ماندگار تبدیل می‌کنم.
            </p>
            <p class="about-p">
              از پرتره تا منظره، از سیاه‌وسفید تا رنگ — هر کار یک روایت است.
            </p>
            <div class="skill-list">
              {skills.map(s => <span class="skill glass">{s}</span>)}
            </div>
            <a href="/about" class="btn btn-primary" style="margin-top:var(--s8)">
              بیشتر بدانید
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ████████ SOCIAL HUB ████████ -->
    <section class="section section-sm" id="contact">
      <div class="container">

        <div class="section-header reveal">
          <span class="tag">ارتباط</span>
          <h2 class="section-title font-display">در همه‌جا پیدام کن</h2>
          <div class="divider divider-center"></div>
          <p class="section-desc">از هر پلتفرمی که راحت‌تری، دنبالم کن</p>
        </div>

        <div class="social-hub reveal">
          <a href="https://instagram.com/rezapix1" target="_blank" rel="noopener" class="soc-card soc-main glass-red">
            <div class="soc-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </div>
            <div class="soc-info">
              <span class="soc-name font-en">Instagram</span>
              <span class="soc-handle font-en">@rezapix1</span>
            </div>
            <span class="soc-arr">↗</span>
          </a>

          <a href="mailto:RpiX1@proton.me" class="soc-card glass">
            <div class="soc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" width="22" height="22"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></div>
            <div class="soc-info">
              <span class="soc-name font-en">Email</span>
              <span class="soc-handle font-en">RpiX1@proton.me</span>
            </div>
            <span class="soc-arr">↗</span>
          </a>

          {[
            { name:'Telegram',  href:'#', svg:`<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>` },
            { name:'YouTube',   href:'#', svg:`<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>` },

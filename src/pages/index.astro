<script define:vars={{ typewriterTexts }}>
  // Typewriter
  const el = document.getElementById('tw');
  let ti = 0, ci = 0, del = false;
  function type() {
    if (!el) return;
    const t = typewriterTexts[ti];
    del ? ci-- : ci++;
    el.textContent = t.slice(0, ci);
    if (!del && ci === t.length) { del = true; setTimeout(type, 2200); return; }
    if (del && ci === 0)         { del = false; ti = (ti+1) % typewriterTexts.length; setTimeout(type, 400); return; }
    setTimeout(type, del ? 45 : 95);
  }
  setTimeout(type, 1000);

  // Scroll reveal
  const obs = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: .1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

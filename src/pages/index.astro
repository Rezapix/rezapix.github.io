---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroScene from '@/components/three/HeroScene';
import MediaPlaceholder from '@/components/ui/MediaPlaceholder.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import PortfolioCard from '@/components/ui/PortfolioCard.astro';
import { getFeaturedPortfolio, BLOG, PRODUCTS, COURSES, PROJECTS } from '@/data/content';
import { SITE } from '@/data/site';
import { formatDate, formatPrice } from '@/lib/utils/format';

const featured = getFeaturedPortfolio();
const latestPosts = BLOG.slice(0, 3);
const featuredProducts = PRODUCTS.filter((p) => p.featured);
const featuredCourse = COURSES.find((c) => c.featured);
---

<BaseLayout
  title={undefined}
  description={SITE.description}
>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative min-h-dvh flex items-center overflow-hidden">
    <HeroScene client:load className="opacity-90" />

    <!-- Gradient masks -->
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--rpix-bg)]/40 via-transparent to-[var(--rpix-bg)] pointer-events-none z-[1]" />
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--rpix-bg)]/80 via-transparent to-[var(--rpix-bg)]/40 pointer-events-none z-[1]" />

    <div class="container-rpix relative z-[2] pt-32 pb-24">
      <div class="max-w-5xl">
        <div class="flex items-center gap-3 mb-8" data-reveal="fade">
          <span class="gold-line" />
          <p class="text-label text-[var(--rpix-gold)]">Creative Operating System</p>
        </div>

        <h1 class="text-hero mb-8" data-reveal>
          Crafted light.<br />
          <span class="text-gradient-gold">Timeless image.</span>
        </h1>

        <p
          class="text-body-lg text-[var(--rpix-muted-fg)] max-w-lg mb-12"
          data-reveal
          data-reveal-delay="120"
        >
          RPIX is a premium studio for photography, cinematography, and color grading —
          built as a living platform for visual excellence.
        </p>

        <div class="flex flex-wrap gap-4" data-reveal data-reveal-delay="200">
          <a href="/portfolio" class="btn btn-primary btn-lg" data-magnetic data-cursor="Enter">
            Explore Work
          </a>
          <a href="/about" class="btn btn-secondary btn-lg" data-magnetic>
            The Studio
          </a>
        </div>
      </div>

      <!-- Scroll cue -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-60">
        <span class="text-label">Scroll</span>
        <div class="w-px h-12 bg-gradient-to-b from-[var(--rpix-gold)] to-transparent animate-pulse" />
      </div>
    </div>

    <!-- Floating stats -->
    <div class="absolute bottom-24 right-[var(--spacing-gutter)] z-[2] hidden xl:flex flex-col gap-6 text-right" data-reveal="right">
      <div>
        <p class="text-h2 text-gradient-gold">12+</p>
        <p class="text-label text-[var(--rpix-muted-fg)]">Years of craft</p>
      </div>
      <div>
        <p class="text-h2">180</p>
        <p class="text-label text-[var(--rpix-muted-fg)]">Select projects</p>
      </div>
      <div>
        <p class="text-h2">HDR</p>
        <p class="text-label text-[var(--rpix-muted-fg)]">Native pipeline</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ DISCIPLINES ═══════════════ -->
  <section class="section-rpix relative">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Disciplines"
        title="Three crafts.<br />One standard."
        description="Every engagement is intentional. We do fewer things, at a higher altitude."
        class="mb-16"
      />

      <div class="grid md:grid-cols-3 gap-4 md:gap-6" data-reveal-stagger>
        {
          [
            {
              href: '/photography',
              title: 'Photography',
              desc: 'Still imagery with cinematic discipline — campaign, editorial, and personal work.',
              label: '01',
            },
            {
              href: '/videography',
              title: 'Videography',
              desc: 'Brand films, automotive, and music visuals directed with restraint and precision.',
              label: '02',
            },
            {
              href: '/color-grading',
              title: 'Color Grading',
              desc: 'Look development and final grade for commercial and feature delivery, SDR + HDR.',
              label: '03',
            },
          ].map((d) => (
            <a
              href={d.href}
              class="group surface-card p-8 md:p-10 relative overflow-hidden transition-all duration-500 hover:border-[rgba(201,168,76,0.3)]"
              data-reveal-child
              data-cursor="Open"
              data-magnetic
            >
              <p class="text-label text-[var(--rpix-gold)] mb-12">{d.label}</p>
              <h3 class="text-h2 mb-4 group-hover:text-[var(--rpix-gold)] transition-colors duration-300">
                {d.title}
              </h3>
              <p class="text-[var(--rpix-muted-fg)] text-sm leading-relaxed mb-8">
                {d.desc}
              </p>
              <span class="inline-flex items-center gap-2 text-sm text-[var(--rpix-fg)] group-hover:gap-3 transition-all">
                Explore
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div class="absolute -bottom-20 -right-20 w-40 h-40 rounded-full bg-[var(--rpix-gold)] opacity-0 group-hover:opacity-5 blur-3xl transition-opacity duration-700" />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════ FEATURED WORK ═══════════════ -->
  <section class="section-rpix !pt-0">
    <div class="container-rpix">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
        <SectionHeading
          eyebrow="Selected Work"
          title="Recent frames."
          description="A living archive of photography, film, and grade."
        />
        <a href="/portfolio" class="btn btn-secondary shrink-0" data-magnetic>
          All Work
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
        {
          featured.map((item, i) => (
            <PortfolioCard item={item} large={i === 0} index={i} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════ CINEMATIC STRIP ═══════════════ -->
  <section class="relative py-8 overflow-hidden">
    <div class="full-bleed">
      <div class="flex gap-4 animate-marquee" style="width: max-content;">
        {
          [...featured, ...featured].map((item) => (
            <div class="w-[280px] md:w-[400px] shrink-0">
              <MediaPlaceholder label={item.title} aspect="photo" class="rounded-lg" gold />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════ PROJECT CASE ═══════════════ -->
  {
    PROJECTS[0] && (
      <section class="section-rpix">
        <div class="container-rpix">
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <div data-reveal="left">
              <MediaPlaceholder label={PROJECTS[0].title} aspect="wide" class="rounded-xl" gold />
            </div>
            <div data-reveal="right">
              <p class="text-label text-[var(--rpix-gold)] mb-4">Case Study</p>
              <h2 class="text-h1 mb-4">{PROJECTS[0].title}</h2>
              <p class="text-[var(--rpix-muted-fg)] mb-2 text-sm">
                {PROJECTS[0].client} · {PROJECTS[0].year}
              </p>
              <p class="text-body-lg text-[var(--rpix-secondary-fg)] mb-8">
                {PROJECTS[0].excerpt}
              </p>
              <blockquote class="border-l-2 border-[var(--rpix-gold)] pl-6 mb-10">
                <p class="text-[var(--rpix-muted-fg)] italic mb-3">
                  “{PROJECTS[0].testimonial?.quote}”
                </p>
                <footer class="text-sm text-[var(--rpix-fg)]">
                  {PROJECTS[0].testimonial?.author}
                  <span class="text-[var(--rpix-muted-fg)]">
                    {' '}
                    — {PROJECTS[0].testimonial?.role}
                  </span>
                </footer>
              </blockquote>
              <a href={`/projects/${PROJECTS[0].slug}`} class="btn btn-primary" data-magnetic>
                View Case Study
              </a>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ═══════════════ PHILOSOPHY ═══════════════ -->
  <section class="section-rpix relative overflow-hidden">
    <div class="absolute inset-0 opacity-30 pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full"
        style="background: radial-gradient(circle, rgba(201,168,76,0.12), transparent 65%);"
      />
    </div>
    <div class="container-rpix relative text-center max-w-4xl mx-auto">
      <p class="text-label text-[var(--rpix-gold)] mb-8" data-reveal="fade">Philosophy</p>
      <h2 class="text-display mb-10" data-reveal>
        Fewer images.<br />Greater weight.
      </h2>
      <p class="text-body-lg text-[var(--rpix-muted-fg)] max-w-2xl mx-auto mb-12" data-reveal data-reveal-delay="100">
        We believe luxury is the absence of the unnecessary. Every frame is edited until only
        intention remains — light shaped, color considered, silence protected.
      </p>
      <a href="/about" class="btn btn-secondary" data-magnetic data-reveal data-reveal-delay="160">
        About the Studio
      </a>
    </div>
  </section>

  <!-- ═══════════════ JOURNAL ═══════════════ -->
  <section class="section-rpix !pt-0">
    <div class="container-rpix">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
        <SectionHeading
          eyebrow="Journal"
          title="Notes on craft."
          description="Essays, field notes, and technical writing from the studio."
        />
        <a href="/blog" class="btn btn-secondary shrink-0" data-magnetic>All Articles</a>
      </div>

      <div class="grid md:grid-cols-3 gap-6" data-reveal-stagger>
        {
          latestPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col"
              data-reveal-child
              data-cursor="Read"
            >
              <MediaPlaceholder label={post.title} aspect="wide" class="rounded-lg mb-5 overflow-hidden" />
              <p class="text-label text-[var(--rpix-muted-fg)] mb-2">
                {formatDate(post.publishedAt ?? post.createdAt)} · {post.readingTime} min
              </p>
              <h3 class="text-h3 mb-2 group-hover:text-[var(--rpix-gold)] transition-colors">
                {post.title}
              </h3>
              <p class="text-sm text-[var(--rpix-muted-fg)] line-clamp-2">{post.excerpt}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════ STORE + COURSES ═══════════════ -->
  <section class="section-rpix !pt-0">
    <div class="container-rpix">
      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Store teaser -->
        <div class="surface-card p-8 md:p-12 relative overflow-hidden" data-reveal>
          <p class="text-label text-[var(--rpix-gold)] mb-4">Store</p>
          <h2 class="text-h1 mb-4">Tools from the suite.</h2>
          <p class="text-[var(--rpix-muted-fg)] mb-8 max-w-md">
            LUTs, presets, and fine art prints — the same materials used in client work.
          </p>
          <div class="flex flex-col gap-4 mb-10">
            {
              featuredProducts.map((p) => (
                <a
                  href={`/store/${p.slug}`}
                  class="flex items-center justify-between gap-4 py-3 border-b border-[var(--rpix-border)] hover:border-[rgba(201,168,76,0.3)] transition-colors group"
                >
                  <span class="group-hover:text-[var(--rpix-gold)] transition-colors">{p.title}</span>
                  <span class="text-sm text-[var(--rpix-muted-fg)] tabular-nums">
                    {formatPrice(p.price, p.currency)}
                  </span>
                </a>
              ))
            }
          </div>
          <a href="/store" class="btn btn-primary" data-magnetic>Visit Store</a>
        </div>

        <!-- Course teaser -->
        {
          featuredCourse && (
            <div class="surface-card p-8 md:p-12 relative overflow-hidden flex flex-col" data-reveal data-reveal-delay="100">
              <p class="text-label text-[var(--rpix-gold)] mb-4">Courses</p>
              <h2 class="text-h1 mb-4">{featuredCourse.title}</h2>
              <p class="text-[var(--rpix-muted-fg)] mb-6 flex-1">{featuredCourse.excerpt}</p>
              <div class="flex items-center gap-4 mb-8">
                <span class="text-label px-3 py-1 rounded-full border border-[var(--rpix-border)]">
                  {featuredCourse.level}
                </span>
                <span class="text-sm text-[var(--rpix-muted-fg)]">
                  {Math.round(featuredCourse.duration / 60)}h · {featuredCourse.lessons.length} lessons
                </span>
                <span class="text-sm text-[var(--rpix-gold)] ml-auto tabular-nums">
                  {formatPrice(featuredCourse.price, featuredCourse.currency)}
                </span>
              </div>
              <a href={`/courses/${featuredCourse.slug}`} class="btn btn-gold" data-magnetic>
                View Course
              </a>
              <div
                class="absolute -bottom-24 -right-24 w-64 h-64 rounded-full opacity-20 pointer-events-none"
                style="background: radial-gradient(circle, rgba(201,168,76,0.4), transparent 70%);"
              />
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA ═══════════════ -->
  <section class="section-rpix">
    <div class="container-rpix">
      <div
        class="relative rounded-2xl overflow-hidden border border-[var(--rpix-border)] px-8 py-20 md:px-16 md:py-28 text-center"
        data-reveal
      >
        <div
          class="absolute inset-0 opacity-40"
          style="background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.15), transparent 60%), linear-gradient(180deg, #0c0c0c, #050505);"
        />
        <div class="relative z-10">
          <p class="text-label text-[var(--rpix-gold)] mb-6">Commission</p>
          <h2 class="text-display mb-6">Ready when you are.</h2>
          <p class="text-body-lg text-[var(--rpix-muted-fg)] max-w-md mx-auto mb-10">
            Share the vision. We'll respond within two business days with availability and next steps.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/contact" class="btn btn-primary btn-lg" data-magnetic data-cursor="Contact">
              Start a Project
            </a>
            <a href={`mailto:${SITE.contact.email}`} class="btn btn-secondary btn-lg" data-magnetic>
              Email the Studio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  .animate-marquee:hover {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee { animation: none; }
  }
</style>

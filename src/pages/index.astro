</Base>

<style>
/* ── HERO ───────────────────────────────── */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding-top: var(--nav-h);
}
.aurora {
  position: absolute;
  inset: -50%;
  z-index: 0;
  pointer-events: none;
}
.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
}
.b1 {
  width: 70%; height: 70%;
  top: 5%; left: 15%;
  background: radial-gradient(ellipse, rgba(170,0,0,.20) 0%, transparent 70%);
  animation: aurora-1 20s ease-in-out infinite;
}
.b2 {
  width: 55%; height: 55%;
  bottom: 10%; right: 5%;
  background: radial-gradient(ellipse, rgba(90,0,25,.13) 0%, transparent 70%);
  animation: aurora-2 26s ease-in-out infinite;
}
.b3 {
  width: 40%; height: 40%;
  top: 45%; left: 3%;
  background: radial-gradient(ellipse, rgba(50,0,50,.08) 0%, transparent 70%);
  animation: aurora-3 30s ease-in-out infinite;
}
.grid-lines {
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background-image:
    linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse at center, transparent 20%, black 100%);
}
.noise {
  position: absolute; inset: 0; z-index: 1; opacity: .03; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px;
}
.hero-inner {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  text-align: center;
  gap: var(--s8);
  padding-block: var(--s20);
}

/* Logo + orbits */
.logo-wrap {
  position: relative;
  width: 160px; height: 160px;
  display: flex; align-items: center; justify-content: center;
  animation: float 7s ease-in-out infinite;
}
.hero-logo {
  width: 110px; height: 110px;
  object-fit: contain;
  position: relative; z-index: 2;
  animation: pulse-red 4s ease-in-out infinite;
}
.orbit {
  position: absolute; border-radius: 50%;
}
.o1 {
  width: 148px; height: 148px;
  border: 1px dashed rgba(204,0,0,.22);
  animation: spin-cw 14s linear infinite;
}
.o2 {
  width: 180px; height: 180px;
  border: 1px solid rgba(255,255,255,.05);
  animation: spin-ccw 22s linear infinite;
}

/* Eyebrow */
.eyebrow {
  display: flex; align-items: center; gap: var(--s4);
  animation: fade-up .8s .3s both;
}
.line {
  display: block; width: 36px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--red), transparent);
}

/* Title */
.hero-title {
  font-size: clamp(3.2rem, 10vw, 8.5rem);
  font-weight: 900;
  line-height: .92;
  letter-spacing: -.02em;
  background: linear-gradient(140deg, #fff 30%, #aaa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: fade-up .8s .5s both;
}
.hero-title .text-red { -webkit-text-fill-color: var(--red); }

/* Subtitle typewriter */
.hero-sub {
  font-size: var(--xl);
  color: var(--text-2);
  letter-spacing: .04em;
  min-height: 2rem;
  animation: fade-up .8s .7s both;

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MediaPlaceholder from '@/components/ui/MediaPlaceholder.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { COURSES } from '@/data/content';
import { formatPrice } from '@/lib/utils/format';
---

<BaseLayout
  title="Courses"
  description="Premium courses on color grading and photography from RPIX."
>
  <section class="pt-36 pb-24">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Learn"
        title="Courses"
        description="Self-paced masterclasses drawn from real commercial and cinematic work."
        class="mb-16"
      />

      <div class="grid lg:grid-cols-2 gap-8" data-reveal-stagger>
        {
          COURSES.map((course) => (
            <a
              href={`/courses/${course.slug}`}
              class="group surface-card overflow-hidden flex flex-col md:flex-row"
              data-reveal-child
              data-cursor="View"
            >
              <div class="md:w-2/5 shrink-0">
                <MediaPlaceholder
                  label={course.title}
                  aspect="portrait"
                  class="rounded-none h-full min-h-[220px]"
                  gold={course.featured}
                />
              </div>
              <div class="p-8 flex flex-col flex-1">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-label px-2.5 py-1 rounded-full border border-[var(--rpix-border)]">
                    {course.level}
                  </span>
                  <span class="text-xs text-[var(--rpix-muted-fg)]">
                    {Math.round(course.duration / 60)} hours
                  </span>
                </div>
                <h2 class="text-h2 mb-3 group-hover:text-[var(--rpix-gold)] transition-colors">
                  {course.title}
                </h2>
                <p class="text-sm text-[var(--rpix-muted-fg)] mb-6 flex-1 line-clamp-3">
                  {course.excerpt}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-lg text-[var(--rpix-gold)] tabular-nums">
                    {formatPrice(course.price, course.currency)}
                  </span>
                  <span class="text-sm text-[var(--rpix-muted-fg)]">
                    {course.lessons.length} lessons
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MediaPlaceholder from '@/components/ui/MediaPlaceholder.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { DOWNLOADS } from '@/data/content';
import { formatFileSize } from '@/lib/utils/format';
---

<BaseLayout
  title="Downloads"
  description="Free templates and resources from RPIX studio."
>
  <section class="pt-36 pb-24">
    <div class="container-rpix">
      <SectionHeading
        eyebrow="Resources"
        title="Downloads"
        description="Practical tools from the production floor — free for the community."
        class="mb-16"
      />

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl" data-reveal-stagger>
        {
          DOWNLOADS.map((d) => (
            <div class="surface-card p-6 flex gap-5" data-reveal-child>
              <div class="w-24 h-24 shrink-0 rounded-lg overflow-hidden">
                <MediaPlaceholder label={d.title} aspect="square" class="rounded-lg" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2 mb-2">
                  <h3 class="text-h3">{d.title}</h3>
                  {d.free && (
                    <span class="text-label text-[var(--rpix-gold)] shrink-0">Free</span>
                  )}
                </div>
                <p class="text-sm text-[var(--rpix-muted-fg)] mb-4 line-clamp-2">{d.excerpt}</p>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-[var(--rpix-muted-fg)]">
                    {d.fileType.toUpperCase()} · {formatFileSize(d.fileSize)} · {d.downloadCount.toLocaleString()} downloads
                  </span>
                  <button type="button" class="btn btn-secondary btn-sm">Download</button>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
